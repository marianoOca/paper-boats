# Host of the deployed PartyKit relay (no protocol, no trailing slash).
# Local dev defaults to 127.0.0.1:1999, so you only need this in production.
# After `npx partykit deploy`, set this to the host it prints, e.g.:
# NEXT_PUBLIC_PARTYKIT_HOST=paper-armada.your-account.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=
